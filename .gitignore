# macOS specific
.DS_Store

# Data files (Do not commit large datasets)
data/raw/*
data/processed/*
!data/**/.gitkeep

# Python specific
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/
venv/
.env

# LaTeX specific
*.aux
*.log
*.out
*.toc
*.fls
*.fdb_latexmk
*.synctex.gz
*.nav
*.snm
*.vrb
*.bbl
*.blg
*.dvi
*.pdf

# Notes LaTeX specific
notes/*.aux
notes/*.log
notes/*.out
notes/*.fls
notes/*.fdb_latexmk
notes/*.synctex.gz
notes/*.pdf

# 実験結果の出力ファイルを除外（**を使用しサブディレクトリ内も適用）
results/metrics/**/*.json
results/final_summary.json

# ただし、空ディレクトリ維持用の.gitkeepは追跡対象として残す
!results/metrics/**/.gitkeep
!results/figures/**/.gitkeep